# NutriSnap Environment Configuration
# Used for local development. Docker Compose overrides these via its own environment block.

DATABASE_URL=postgresql://nutrisnap:nutrisnap_pass@db:5432/nutrisnap
ADMIN_INITIAL_PASSWORD=ProductionPassword123!
USE_MOCK_HEALTH_API=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_secret_here
GEMINI_API_KEY=your_gemini_api_key_here
