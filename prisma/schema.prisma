generator client {
  provider      = "prisma-client-js"
  output        = "./generated/client"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  telegramId            String?   @unique
  name                  String?
  password              String
  role                  String    @default("USER")
  onboarded             Boolean   @default(false)
  requiresPasswordReset Boolean   @default(false)
  gender                String?
  age                   Int?
  weight                Float?
  height                Float?
  mealLogs              MealLog[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model MealLog {
  id            String     @id @default(cuid())
  userId        String
  category      String
  time          String
  imagePath     String?
  description   String?
  totalCalories Float
  totalProtein  Float
  totalCarbs    Float
  totalFat      Float
  totalFiber    Float
  totalSatFat   Float
  totalSugar    Float
  healthInsight String?
  items         FoodItem[]
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model FoodItem {
  id           String   @id @default(cuid())
  mealLogId    String
  name         String
  grams        Float
  calories     Float
  protein      Float
  carbs        Float
  fat          Float
  fiber        Float
  saturatedFat Float
  sugar        Float
  mealLog      MealLog  @relation(fields: [mealLogId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
